# ── paste.trade API ──────────────────────────────────────────────────────────
PASTE_TRADE_KEY=                   # paste.trade API bearer token

# ── X / Twitter (agent-twitter-client — same as Swarmsy) ────────────────────
TWITTER_AUTH_TOKEN=                # auth_token cookie from x.com (DevTools → Application → Cookies)
TWITTER_CT0=                       # ct0 cookie from x.com (same place — the CSRF token)
PROXY_URL=                         # optional rotating proxy: http://user:pass@host:port
XACTIONS_SESSION_COOKIE=           # auth_token for xactions Puppeteer fallback path

# ── AI (optional — powers "What's The Trade?" feature) ──────────────────────
ANTHROPIC_API_KEY=                 # Claude API key for trade analysis

# ── Database (Neon Postgres) ─────────────────────────────────────────────────
DATABASE_URL=                      # Neon Postgres connection string (postgres://...)

# ── URLs ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000  # base URL for OG image generation

# ── Public API (optional) ────────────────────────────────────────────────────
# Pre-seed developer-tier keys without going through POST /v1/keys.
# JSON array format:  [{"key":"pt_xxx","tier":"developer","handle":"you"}]
# Comma-separated:    pt_key1,pt_key2   (all treated as "free" tier)
# Keys issued via POST /v1/keys are stored in the database.
# This env var is only used as a fallback / initial seed.
PT_API_KEYS=

# ── Solana (wager system) ──────────────────────────────────────────────────
SOLANA_RPC_URL=                   # Solana RPC endpoint (defaults to mainnet-beta public)
SOLANA_PROGRAM_ID=                # Deployed wager program ID for PDA vault derivation
